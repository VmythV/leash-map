# LeashMap server config. Copy to .env for local overrides.
LEASHMAP_APP_ENV=local

# Placeholder for the future PostgreSQL/PostGIS backend (unused by the
# in-memory MVP store).
# LEASHMAP_DATABASE_URL=postgresql://leashmap:leashmap@localhost:5432/leashmap

# If set, device uploads must present this exact bearer token.
# Leave unset in local to accept any non-empty device token.
# LEASHMAP_DEVICE_TOKEN=dev-token

# Geofence / alert tuning (see docs/api/realtime-events.md).
LEASHMAP_GEOFENCE_ACCURACY_THRESHOLD_M=50
LEASHMAP_GEOFENCE_EXIT_CONSECUTIVE=2
LEASHMAP_LOW_BATTERY_THRESHOLD=15
